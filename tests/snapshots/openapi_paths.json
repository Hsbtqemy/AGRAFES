  "/documents/delete": {
    "post": {
      "summary": "Delete documents and all associated data (units, alignment links, relations)",
      "security": [
        {
          "token": []
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": [
                "doc_ids"
              ],
              "properties": {
                "doc_ids": {
                  "type": "array",
                  "items": {
                    "type": "integer"
                  },
                  "minItems": 1
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Deleted",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ok": {
                    "type": "boolean"
                  },
                  "deleted": {
                    "type": "integer"
                  },
                  "doc_ids": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "400": {
          "description": "Bad request"
        },
        "401": {
          "description": "Unauthorized"
        }
      }
    }
  },
