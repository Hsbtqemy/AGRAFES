    "@tauri-apps/plugin-shell": "^2.0.0",
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "cross-env": "^10.1.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
