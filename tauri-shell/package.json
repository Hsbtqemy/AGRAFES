{
  "name": "agrafes-shell",
  "version": "0.2.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:prune": "eslint \"src/**/*.ts\" --prune-suppressions",
    "tauri": "tauri",
    "tauri:build:windows": "tauri build --config src-tauri/tauri.windows.conf.json --bundles nsis",
    "build:sidecar": "cross-env PYTHONPATH=../src python ../scripts/build_sidecar.py --preset shell --format onefile"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-deep-link": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-http": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "chart.js": "^4.5.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "happy-dom": "^20.10.6",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
