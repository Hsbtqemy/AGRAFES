{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AGRAFESShell",
  "version": "0.1.20",
  "identifier": "com.agrafes.shell",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1422"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AGRAFES Shell",
        "width": 1200,
        "height": 760,
        "minWidth": 800,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["multicorpus"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "AGRAFES — corpus preparation and concordancier",
    "longDescription": "AGRAFES Shell unifies multilingual corpus preparation (import, curation, segmentation, alignment, export) and concordancier in a single desktop application. Requires no external Python runtime.",
    "copyright": "2024-2026 AGRAFES",
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["agrafes-shell"]
      }
    }
  }
}
