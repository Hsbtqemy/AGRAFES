{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AGRAFESShell",
  "version": "0.1.0",
  "identifier": "com.agrafes.shell",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1422"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AGRAFES Shell",
        "width": 1200,
        "height": 760,
        "minWidth": 800,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["multicorpus"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["agrafes-shell"]
      }
    }
  }
}
